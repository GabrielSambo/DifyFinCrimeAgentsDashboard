# Veritas environment configuration. Copy to .env.local and fill in real values.
# Server-side only — never commit real values; never expose to the browser.

# Dify API base (the agents platform)
DIFY_API_BASE=https://your-dify-host/v1

# Dify app keys (one per agent)
DIFY_UBO_APP_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx      # Beneficial-ownership agent
DIFY_KYC_APP_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx      # KYC onboarding agent
DIFY_PEP_APP_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx      # PEP / sanctions screening app
DIFY_RFI_APP_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx      # RFI / document-request agent (optional)

# Supabase (client record of truth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key         # server-side only
